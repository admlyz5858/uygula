{
  "name": "lockscreennotes",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --platform android --clean",
    "build:apk": "cd android && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk ../release/LockScreenNotes-debug.apk",
    "build:apk:release": "cd android && ./gradlew assembleRelease && cp app/build/outputs/apk/release/app-release.apk ../release/LockScreenNotes-release.apk"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~55.0.6",
    "expo-font": "^55.0.4",
    "expo-haptics": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
